# Node modules (always ignore)
node_modules/

# Environment variables (never push secrets)
.env
.env.local
.env.production

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Database dumps / local database files
data/
*.sqlite
*.db

# Uploaded files (optional)
uploads/

# OS files
.DS_Store
Thumbs.db

# Docker
# If you don’t want local Docker stuff pushed
docker-compose.override.yml

# IDE / editor files (optional but professional)
.vscode/
.idea/
